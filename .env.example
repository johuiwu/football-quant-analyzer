# DEEPSEEK_API_KEY: DeepSeek AI API密钥
# 用于驱动 AI 战术推演、球队画像、赛事点评功能
# 缺失时自动降级为离线模式，核心量化模型不受影响
DEEPSEEK_API_KEY="MY_DEEPSEEK_API_KEY"

# APP_URL: 应用部署URL (生产环境使用)
APP_URL="MY_APP_URL"

# PUPPETEER_PROXY: Puppeteer 浏览器代理地址
# 支持 HTTP/HTTPS/SOCKS5 代理，用于访问目标网站
# 设置后浏览器通过代理连接，未设置则直连
# 示例: socks5://127.0.0.1:7890 (Clash SOCKS5)
# 示例: http://127.0.0.1:7890 (Clash HTTP)
# 示例: socks5://127.0.0.1:1080 (V2Ray/Shadowsocks)
# PUPPETEER_PROXY="socks5://127.0.0.1:7890"
